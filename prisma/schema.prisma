generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(cuid())
  name             String?
  email            String?   @unique
  emailVerified    DateTime?
  password         String?
  image            String?
  phone            String?
  address          String?
  city             String?
  district         String?
  role             String    @default("customer")
  status           String    @default("active")
  permissions      String    @default("")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  resetToken       String?   @unique
  resetTokenExpiry DateTime?
  accounts         Account[]
  sessions         Session[]
  orders           Order[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Setting {
  id               String   @id @default("site-settings")
  siteName         String?  @default("KC Bazar")
  marqueeText      String   @default("Welcome to KC Bazar! Free shipping on orders over ৳1000.")
  announcements    String   @default("[\"Welcome to KC Bazar! Free shipping on orders over ৳1000.\"]")
  hotline          String   @default("09644888889")
  openingHours     String   @default("Sat - Thu: 10:00 AM - 08:00 PM")
  location         String   @default("Model Town, Puran Para, Bandarban")
  email            String   @default("hello@kcbazar.com")
  facebook         String   @default("https://facebook.com")
  instagram        String   @default("https://instagram.com")
  whatsapp         String   @default("https://wa.me/880123456789")
  themeColor       String   @default("#FF4D6D")
  logoUrl          String   @default("https://kcbazar.com/wp-content/uploads/2025/08/KCB-LOGO-G.png")
  faviconUrl       String   @default("/favicon.ico")
  shortDescription String   @default("Your one-stop premium destination for beauty and wellness.")
  siteTitle        String   @default("KC Bazar | Premium Beauty & Wellness")
  siteDescription       String   @default("Shop the best beauty and wellness products at KC Bazar. Your one-stop premium destination.")
  siteKeywords          String   @default("ecommerce, beauty, wellness, shopping, bangladesh")
  shippingPromoTitle    String   @default("নিশ্চিত হোম ডেলিভারি! 🚚")
  shippingPromoSubtitle String   @default("কেসি বাজারে কেনাকাটা করা এখন আরও সহজ। আপনার কাঙ্ক্ষিত পণ্যটি অর্ডার করুন এবং বুঝে নিন আপনার ঘরের দোরগোড়ায়। সারা বাংলাদেশে ক্যাশ অন ডেলিভারি সুবিধা থাকছে আমাদের সাথে।")
  shippingPromoImageUrl String   @default("https://kcbazar.com/wp-content/uploads/2025/09/shipping--600x440.png")
  aboutUsTitle          String   @default("কেসি বাজার সম্পর্কে")
  aboutUsDescription    String   @default("কেসি বাজার বাংলাদেশে অরিজিনাল কোরিয়ান স্কিনকেয়ার এবং কসমেটিকস পণ্যের অন্যতম নির্ভরযোগ্য প্রতিষ্ঠান।")
  aboutUsImageUrl       String   @default("https://kcbazar.com/wp-content/uploads/2025/08/about-us-demo.png")
  shippingPolicy        String   @default("Our shipping policy details...")
  refundPolicy          String   @default("Our refund policy details...")
  privacyPolicy         String   @default("Our privacy policy details...")
  termsConditions       String   @default("Our terms and conditions...")
  faqContent            String   @default("Frequently asked questions...")
  careerContent         String   @default("Career opportunities at KC Bazar...")
  orderConfirmMsg1      String   @default("আপনার অর্ডারটি আগামী ২৪ ঘন্টার মধ্যে আমাদের কাস্টমার কেয়ার প্রতিনিধি ফোন দিয়ে কনফার্ম করবেন (শুক্রবার ব্যতীত)।")
  orderConfirmMsg2      String   @default("ফোন কনফার্ম হওয়ার ২৪-৪৮ ঘণ্টার মধ্যে আপনি আপনার অর্ডারটি হাতে পেয়ে যাবেন।")
  orderConfirmMsg3      String   @default("বিঃদ্রঃ কোনো কারনে ফোন কল না পেলে, আপনার অর্ডারটি হোল্ড অবস্থায় থাকবে। অনুগ্রহ করে আমাদের কাস্টমার কেয়ারের কলটি রিসিভ করবেন।")
  orderConfirmHotline   String   @default("09613660321")
  orderConfirmFooter    String   @default("ধন্যবাদ kcbazar এর সাথে থাকার জন্য!")
  updatedAt             DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  status    String   @default("unread")
  createdAt DateTime @default(now())
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  image       String?
  parentId    String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  parent      Category?  @relation("ParentChild", fields: [parentId], references: [id])
  children    Category[] @relation("ParentChild")
}

model Menu {
  id        String   @id @default(cuid())
  label     String
  href      String
  order     Int      @default(0)
  isHot     Boolean  @default(false)
  type      String   @default("header")
  parentId  String?
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  parent    Menu?    @relation("MenuToSubmenu", fields: [parentId], references: [id])
  children  Menu[]   @relation("MenuToSubmenu")
}

model HeroSlide {
  id              String   @id @default(cuid())
  imageUrl        String
  mobileImageUrl  String?
  linkUrl         String?  @default("/")
  order           Int      @default(0)
  isActive        Boolean  @default(true)
  isAllProducts   Boolean  @default(false)
  products        Product[] @relation("HeroSlideProducts")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Product {
  id           String   @id @default(cuid())
  name         String
  shortBrief   String?
  description  String?
  additionalInfo String?
  ingredients  String?
  brand        String?
  brandImage   String?
  category     String?
  regularPrice Float
  salePrice    Float?
  discount     String?
  stock        Int      @default(0)
  sku          String?
  image        String
  images       String?
  isFeatured   Boolean  @default(false)
  isActive     Boolean  @default(true)
  isClearance  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  reviews      Review[]
  orderItems   OrderItem[]
  heroSlides   HeroSlide[] @relation("HeroSlideProducts")
  banners      Banner[]    @relation("BannerProducts")
}

model Review {
  id        String   @id @default(cuid())
  productId String
  userName  String
  userEmail String?
  rating    Int
  comment   String
  status    String   @default("approved")
  isDummy   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}
model Banner {
  id              String   @id @default(cuid())
  imageUrl        String
  linkUrl         String?  @default("/")
  position        String
  order           Int      @default(0)
  isActive        Boolean  @default(true)
  isAllProducts   Boolean  @default(false)
  products        Product[] @relation("BannerProducts")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Brand {
  id        String   @id @default(cuid())
  name      String
  imageUrl  String
  linkUrl   String?  @default("/")
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  customerName    String
  customerEmail   String?
  customerPhone   String
  customerAddress String
  customerCity    String
  customerArea    String?
  totalAmount     Float
  subtotal        Float
  discount        Float       @default(0)
  shippingFee     Float       @default(0)
  couponId        String?
  paymentMethod   String      @default("COD")
  status          String      @default("pending")
  userId          String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  user            User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  coupon          Coupon?     @relation(fields: [couponId], references: [id])
  orderItems      OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  productName String
  quantity  Int
  price     Float
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
}

model Coupon {
  id              String   @id @default(cuid())
  code            String   @unique
  discountType    String   @default("percentage") // "percentage" or "fixed"
  discountValue   Float
  minOrderAmount  Float?   @default(0)
  maxDiscount     Float?
  usageLimit      Int?     // null means unlimited
  usageCount      Int      @default(0)
  expiryDate      DateTime?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  orders          Order[]
}

